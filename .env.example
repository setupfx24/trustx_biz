# =============================================================
# trustx — Single .env (repo root) — ONE file for everything
# =============================================================
# Copy to .env and fill in real values. Never commit .env to git.
#
# This file is the ONLY .env needed:
#   • Docker Compose reads it for ${VAR} substitution in docker-compose.yml
#   • All backend services load it via env_file
#   • Frontend containers use only the vars set in docker-compose.yml environment:
#
# DO NOT create backend/.env — it is no longer used.
# =============================================================

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=trustx
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=trustx

# ─── TimescaleDB ──────────────────────────────────────────────
TIMESCALE_USER=trustx
TIMESCALE_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
TIMESCALE_DB=marketdata

# ─── Connection URLs (must match passwords above) ─────────────
DATABASE_URL=postgresql+asyncpg://trustx:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/trustx
TIMESCALE_URL=postgresql+asyncpg://trustx:CHANGE_THIS_STRONG_PASSWORD@timescaledb:5432/marketdata
REDIS_URL=redis://redis:6379/0

# ─── JWT Secrets — generate with: openssl rand -hex 32 ────────
JWT_SECRET=CHANGE_THIS_RANDOM_64_CHAR_STRING
USER_JWT_SECRET=CHANGE_THIS_RANDOM_64_CHAR_STRING
ADMIN_JWT_SECRET=CHANGE_THIS_OTHER_RANDOM_64_CHAR_STRING
# Access JWT lifetime (minutes). Refresh cookie is separate (JWT_REFRESH_EXPIRY_DAYS).
# Legacy env name JWT_EXPIRY_MINUTES is still accepted as an alias.
JWT_ACCESS_EXPIRY_MINUTES=45
JWT_REFRESH_EXPIRY_DAYS=7
# true = access + refresh cookies are browser-session only (close browser → log in again).
# false = persistent cookies (access ~JWT_ACCESS_EXPIRY_MINUTES, refresh JWT_REFRESH_EXPIRY_DAYS).
JWT_REFRESH_SESSION_COOKIE=true
# HttpOnly cookie flags (trader web). Leave COOKIE_SECURE unset to auto-detect HTTPS.
COOKIE_SAMESITE=strict
# COOKIE_SECURE=true
# Cookie Domain — set to a parent domain so the same session works on apex + trade subdomain.
# Production:
COOKIE_DOMAIN=.trustx.biz
# Local dev: leave blank or comment out (host-only cookies on localhost are correct).
# Set false only for local HTTP if browsers reject Secure cookies.
# JWT_INCLUDE_LEGACY_JSON_TOKEN=false

# Include the raw refresh token in the JSON body of /auth/login,
# /auth/google, /auth/wallet/verify, /auth/refresh, etc. Required for
# mobile clients (which cannot use HttpOnly cookies). Web does not need
# this — it reads pt_refresh from the cookie. Default is false in
# production .env; enable here so local-dev mobile builds work out of
# the box against `docker compose up`.
JWT_INCLUDE_REFRESH_IN_JSON=true

# ─── Environment & CORS ───────────────────────────────────────
ENVIRONMENT=production
# Trader (apex + user-app subdomain) + admin origins
CORS_ORIGINS=https://trustx.biz,https://trade.trustx.biz,https://admin.trustx.biz
# Trader site origin for password-reset email links (no trailing slash) — points at the user-app subdomain
TRADER_APP_URL=https://trade.trustx.biz

# Build-time host pair for trader-frontend (enables the marketing/app domain split).
# Marketing pages stay on NEXT_PUBLIC_MARKETING_HOST; everything else (auth, dashboard,
# wallet, portfolio, trading terminal, etc.) is served from NEXT_PUBLIC_TRADE_HOST.
# Leave blank for local dev so src/middleware.ts no-ops and a single host serves all routes.
NEXT_PUBLIC_MARKETING_HOST=trustx.biz
NEXT_PUBLIC_TRADE_HOST=trade.trustx.biz

# ─── Outbound email (password reset) ───────────────────────────
# If SMTP_HOST is empty, reset emails are NOT sent (production logs a warning; dev logs the link).
# Gmail: enable 2FA, create an App Password, use smtp.gmail.com:587, your full address as SMTP_USER.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM=trustx <you@gmail.com>
# SMTP_USE_TLS=true

# ─── Per-category From aliases (recommended for Hostinger setups) ──
# SMTP still authenticates as SMTP_USER (the support@ mailbox owner),
# but the visible "From:" header swaps to a topical alias based on
# what the email is about. Configure the alias(es) in your mail
# provider first, then drop the bare addresses here (no display name).
#
# Map (default categories used by trustx code):
#   account     → deposits / withdrawals / margin call / stop-out / statements
#   insure      → insured-trade payouts / reminders (Insurance product)
#   affiliates  → IB / PAMM / MAM (when those flows start sending emails)
#   voucher     → bonus credits / referral payouts / tier upgrades / missions
#   stacking    → fixed-return + staking notices
#   info        → maintenance broadcasts / generic touches (default fallback)
#   support     → email verification, password reset, KYC approve/reject, dashboard access
#
# Leave any field blank to fall back to SMTP_FROM / SMTP_USER for that
# category — existing single-address deployments keep working unchanged.
# SMTP_FROM_ACCOUNT=account@trustx.biz
# SMTP_FROM_INSURE=insure@trustx.biz
# SMTP_FROM_AFFILIATES=affiliates@trustx.biz
# SMTP_FROM_VOUCHER=voucher@trustx.biz
# SMTP_FROM_STACKING=stacking@trustx.biz
# SMTP_FROM_INFO=info@trustx.biz
# SMTP_FROM_SUPPORT=support@trustx.biz

# ─── Email branding ────────────────────────────────────────────
# Absolute https URL to the logo image rendered at the top of every
# transactional email. Email clients can't load relative paths, so it
# must point at a public asset (defaults to the refreshed brand logo
# served by the trader-frontend at /images/trustx_png5.png). Set to
# empty to fall back to the styled "trustx" wordmark text.
# EMAIL_LOGO_URL=https://trustx.biz/images/trustx_png5.png

# ─── Mobile app store links ─────────────────────────────────────
# When at least one is set, every email renders a green "Trade anywhere —
# get the trustx app" footer banner with App Store + Google Play badges.
# Leave both empty until the apps actually ship — broken store links in
# emails look worse than not advertising the app at all.
#
# Drop the official badge PNGs at frontend/trader/public/images/email/
# (see frontend/trader/public/images/email/README.md). Apple's marketing
# tools page: https://tools.applemediaservices.com/app-store/. Google
# Play badge generator: https://play.google.com/intl/en_us/badges/.
IOS_APP_URL=
ANDROID_APP_URL=
# EMAIL_IOS_BADGE_URL=https://trustx.biz/images/email/app-store-badge.png
# EMAIL_ANDROID_BADGE_URL=https://trustx.biz/images/email/google-play-badge.png

# ─── Support quick-contact (trader app) ────────────────────────
# Surfaced on /support above the ticket list. Either can be left
# empty — the matching button simply hides. WhatsApp number must be
# in international format WITHOUT the leading '+' (digits only); the
# UI builds a wa.me/<digits> link from it.
NEXT_PUBLIC_SUPPORT_EMAIL=support@trustx.biz
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# ─── Admin service ────────────────────────────────────────────
ADMIN_REDIS_URL=redis://redis:6379/1

# ─── Risk engine ──────────────────────────────────────────────
MARGIN_CALL_LEVEL=80.0
STOP_OUT_LEVEL=50.0
MAX_OPEN_TRADES=200
DEFAULT_LEVERAGE=100

# KYC file storage (gateway). Use an absolute path on a writable volume in production, e.g. /app/data/kyc
# KYC_UPLOAD_ROOT=/app/data/kyc
# Manual deposit screenshots + user payout QR images — mount the same path on gateway AND admin services.
# WALLET_UPLOAD_ROOT=/app/data/wallet

# ─── CORS (locked down for production) ─────────────────
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Requested-With,Accept

# ─── Sentry (error monitoring) ────────────────────────
# Leave empty to disable. Get a DSN from https://sentry.io
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_TRADING=120/minute

# ─── Request Size Limit (bytes, default 10 MB) ────────
MAX_REQUEST_SIZE=10485760

# ─── Google OAuth (Sign in / Sign up with Google) ─────
# Get a Web-application Client ID from https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins must include https://trustx.biz, https://trade.trustx.biz,
# and (for local dev) http://localhost:3010. No redirect URI is needed — we use the implicit
# id_token flow. The same value is exposed to the browser as NEXT_PUBLIC_GOOGLE_CLIENT_ID.
# Leave empty to disable Google sign-in (button is hidden, /auth/google returns 503).
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── NOWPayments crypto deposits ──────────────────────
# Hosted-invoice flow: user picks a crypto asset on the wallet page, we create
# an invoice via /v1/invoice with pay_currency pre-locked, and redirect them
# to NOWPayments' invoice_url. They pay; NOWPayments POSTs an IPN to
# https://${NOWPAYMENTS_CALLBACK_BASE_URL}/api/v1/webhooks/nowpayments
# signed with HMAC-SHA512 over the sorted-key JSON body using IPN_SECRET.
#
# Where to get these:
#   API key:    https://account.nowpayments.io/store-settings/api-keys
#   IPN secret: https://account.nowpayments.io/store-settings/ipn-settings
#
# Set NOWPAYMENTS_SANDBOX=true to point at api-sandbox.nowpayments.io for
# testnet smoke tests. Leave empty (or unset NOWPAYMENTS_API_KEY) and the
# /wallet/deposit endpoint returns "NOWPayments not configured".
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false
NOWPAYMENTS_CALLBACK_BASE_URL=https://api.trustx.biz

# WalletConnect project id (Reown Cloud) — required by RainbowKit so the
# WalletConnect QR + mobile-deeplink flows work. Get one (free) at
# https://cloud.reown.com → Create Project → copy "Project ID". Without it,
# RainbowKit only surfaces injected wallets (MetaMask, OKX, Brave) and the
# WalletConnect-based ones (Trust Wallet mobile, etc.) won't connect.
# Baked into the trader-frontend bundle at Docker build time.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Market Data (AllTick) ────────────────────────────
# Real-time forex / metals / crypto / index-CFD ticks via WebSocket.
# Get a token at https://alltick.co (paid plan recommended for full
# symbol coverage; free tier limits to 5 symbols / 1 connection).
# Used by Docker service `market-data` (publishes ticks to Redis); the
# gateway and trader frontend read prices from Redis.
# Empty / placeholder → market-data falls back to FeedSimulator (crypto via Binance).
ALLTICK_TOKEN=your-alltick-token-here
# Override only if AllTick directs you to a regional endpoint:
# ALLTICK_FOREX_WS_URL=wss://quote.alltick.co/quote-b-ws-api
# ALLTICK_STOCK_WS_URL=wss://quote.alltick.co/quote-stock-b-ws-api

# ─── Default admin UI login (init-db.sql + alembic revision 0002) ───
# Set these before running migrations to seed the super_admin with your desired credentials.
# Change password after first login; run: docker compose --profile migrate run --rm migrate
ADMIN_EMAIL=admin@trustx.biz
ADMIN_PASSWORD=trustxAdmin2025!


# ─── Backup & Disaster Recovery ───────────────────────
# Daily Postgres + TimescaleDB + uploads/ snapshots. See scripts/backup.sh
# and docs/disaster-recovery.md for the full pipeline + restore runbook.
#
# Local backup directory on the host. The script creates it automatically.
BACKUP_LOCAL_DIR=/opt/trustx/backups
# Days of local + remote backups to retain. Older archives are deleted by
# the daily cron sweep.
BACKUP_RETENTION_DAYS=14
# Optional rclone remote name + path. Empty = local-only (NOT safe for
# prod — losing the disk loses the backup too). Configure once with
# `rclone config` then put the remote name here, e.g. "b2:trustx-backups".
# Recommended provider: Backblaze B2 ($0.005/GB/mo, free egress for 3×).
BACKUP_RCLONE_REMOTE=

# ─── Backup encryption (REQUIRED — backup.sh refuses to run without one) ──
# Pick ONE of the two:
#
#   1) Public-key (recommended): your ops GPG key. Generate / publish:
#        gpg --full-generate-key        (RSA 4096, name "trustx Ops")
#        gpg --export ops@trustx.biz > ops.pub  ; import on the host
#      Backups are encrypted to this recipient; private key never leaves
#      your password manager / HSM.
# BACKUP_GPG_RECIPIENT=ops@trustx.biz
#
#   2) Symmetric (simpler bootstrap): a long random passphrase in a file.
#      File mode MUST be 600. Store the passphrase ALSO in 1Password /
#      Bitwarden — losing it = losing every backup.
# BACKUP_GPG_PASSPHRASE_FILE=/etc/trustx/backup.pass


