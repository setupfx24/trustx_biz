*.docx
*.doc
*.pdf
*.xlsx
*.xls
*.ppt
*.pptx
*.zip
*.tar
*.tar.gz

# Exception — public-facing legal PDFs the Terms page links to. Anything
# inside this exact folder is shipped with the site so the View / Download
# buttons under /terms actually resolve. Other PDFs across the repo stay
# ignored.
!frontend/trader/public/pdfs/terms/
!frontend/trader/public/pdfs/terms/*.pdf
*.tgz
*.7z
*.rar
*.bak
~$*

# Client reference mockups dropped at the repo root (kept locally only)
/ChatGPT Image*.png
/ChatGPT Image*.jpg
